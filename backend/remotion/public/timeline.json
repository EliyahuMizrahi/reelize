          "speaker": "SPEAKER_01"
        },
        {
          "end": 44.584,
          "text": "Love me.",
          "start": 43.504,
          "speaker": "SPEAKER_00"
        },
        {
          "end": 49.549,
          "text": "If the game ends here, it ends on my terms.",
