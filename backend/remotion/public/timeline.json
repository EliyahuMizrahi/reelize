    "voice": {
      "turns": [
        {
          "end": 4.997,
          "text": "Imagine you're Garen. Your entire team is dead and the enemy team is looking to end the game.",
          "start": 1.357,
          "speaker": "SPEAKER_02"
        },
        {
          "end": 8.361,
          "text": "Would you flash into four people to defend your base?",
          "start": 5.297,
          "speaker": "SPEAKER_02"
        },
        {
          "end": 10.761,
          "text": "As Garen, no, I wouldn't flash into four people there.",
          "start": 8.561,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 13.941,
          "text": "My whole team is dead, so even if I go in, I'm not actually saving the game.",
          "start": 10.881,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 15.041,
          "text": "I'm just dying faster.",
          "start": 14.061,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 17.901,
          "text": "Flashing in guarantees I get focused and killed with no follow-up.",
          "start": 15.401,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 20.121,
          "text": "I'd retreat, regroup, and wait for respawns.",
          "start": 18.041,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 25.119,
          "text": "Better to defend with numbers than throw myself into a 1v4 and lose anyway.",
          "start": 20.301,
          "speaker": "SPEAKER_03"
        },
        {
          "end": 26.699,
          "text": "I'm flashing the fuck in.",
          "start": 25.339,
          "speaker": "SPEAKER_01"
        },
        {
          "end": 28.039,
          "text": "Love me.",
          "start": 27.239,
          "speaker": "UNKNOWN"
        },
        {
          "end": 32.986,
          "text": "My teammates will not respawn in time to defend with me.",
          "start": 29.519,
          "speaker": "SPEAKER_01"
        },
        {
          "end": 36.606,
          "text": "And I refuse to just stand here and watch them take our base.",
          "start": 32.986,
          "speaker": "SPEAKER_01"
        },
        {
          "end": 38.146,
          "text": "Love me.",
          "start": 36.786,
          "speaker": "SPEAKER_00"
        },
        {
          "end": 43.184,
          "text": "One flash to close the gap and one spin to wipe them all.",
