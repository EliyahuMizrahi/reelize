  "captions": [
    {
      "text": "Imagine you're a\nrouter. Fifteen",
      "start": 1.3666666666666667,
      "end": 3.2666666666666666,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "devices in your house\nall want the internet.",
      "start": 3.2666666666666666,
      "end": 5.133333333333334,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Do you give every\nphone its own public",
      "start": 5.266666666666667,
      "end": 6.5,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "IP address?",
      "start": 6.5,
      "end": 7.733333333333333,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "No. That doesn't\nscale.",
      "start": 8.533333333333333,
      "end": 9.966666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "IPv4 only has four\nbillion addresses, and",
      "start": 10.833333333333334,
      "end": 12.2,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "we've already run out.",
      "start": 12.2,
      "end": 13.566666666666666,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "It's impossible.",
      "start": 14.0,
      "end": 15.1,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Every device would\nneed a global slot.",
      "start": 15.333333333333334,
      "end": 17.233333333333334,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Better to share one\npublic IP.",
      "start": 17.966666666666665,
      "end": 19.533333333333335,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "And rewrite the source\naddress on the way",
      "start": 20.2,
      "end": 21.8,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "out, so replies still\nfind home.",
      "start": 21.8,
      "end": 23.366666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Network Address\nTranslation.",
      "start": 25.233333333333334,
      "end": 26.8,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "One IP.",
      "start": 27.1,
      "end": 27.933333333333334,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Every private IP gets\nswapped for my public",
      "start": 29.366666666666667,
      "end": 30.866666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "one on the way out.",
      "start": 30.866666666666667,
      "end": 32.4,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "I log the source port\nso replies come back",
      "start": 32.833333333333336,
      "end": 33.96666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "right.",
      "start": 33.96666666666667,
      "end": 35.06666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Rewritten.",
      "start": 36.6,
      "end": 37.46666666666667,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "One public IP. A\nhundred devices behind",
      "start": 38.86666666666667,
      "end": 40.53333333333333,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "it. All online at\nonce.",
      "start": 40.53333333333333,
      "end": 42.166666666666664,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "Shared.",
      "start": 43.3,
      "end": 44.03333333333333,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "A reply hits my port.\nI find the owner. I",
      "start": 45.36666666666667,
      "end": 46.8,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width_px": 3,
        "position": "middle",
        "animation": "pop",
        "case": "mixed",
        "background": null
      }
    },
    {
      "text": "send it home.",
      "start": 46.8,
      "end": 48.233333333333334,
      "style": {
        "font_feel": "impact-bold",
        "weight": 800,
        "size": 104,
