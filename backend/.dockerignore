# Secrets / env files — never bake into images
.env
.env.*
!.env.example

# Local caches and transient artifacts
tmp/
clips/
ffmpeg_shared/
ffmpeg_shared.zip

# Python build / cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Large/binary media that should not ship inside the image
*.mp4
*.wav
*.mov
*.mkv

# Git + editor noise
.git/
.gitignore
.vscode/
.idea/

# Node (in case docker build is ever run from repo root)
node_modules/
