# Secrets — never commit real env files
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/settings.local.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Node
node_modules/

# Runtime / generated artifacts
tmp/
clips/
ffmpeg_shared/
ffmpeg_shared.zip

# Background footage library — binaries, not source
backend/assets/bg_footage/**
!backend/assets/bg_footage/.gitkeep
!backend/assets/bg_footage/README.md

# Remotion render cache
backend/remotion/node_modules/
backend/remotion/.cache/
backend/remotion/out/
